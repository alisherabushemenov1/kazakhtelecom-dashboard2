# Copy this file to .env and fill in your real values.
# copy .env.example .env (Windows)

DATA_SOURCE=sheets

GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_GID=your_sheet_gid
GOOGLE_SHEET_NAME=БКВ 2026
SHEETS_POLL_INTERVAL=30
GOOGLE_CREDENTIALS_PATH=google-credentials.json

EXCEL_PATH=../data/projects.xlsx

HOST=0.0.0.0
PORT=8001

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/kazakhtelecom_dashboard?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=kazakhtelecom_dashboard

JWT_SECRET=replace-with-a-long-random-secret-key
JWT_EXPIRES_MINUTES=10080
